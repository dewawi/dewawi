<?php
$this->title = $this->translate('UPLOAD');
$this->headTitle($this->title);
?>
<script type="text/javascript">
$(document).ready(function () {
	var $parentAttachments = $('#attachments', parent.document);
	var $newItems = $('#uploads').children();

	$newItems.each(function () {
		var attachmentId = $(this).attr('id');

		if (attachmentId) {
			$('#' + attachmentId, parent.document).remove();
		}

		$parentAttachments.append($(this));
	});

	$('#attachments input[type="checkbox"][name="file[]"]', parent.document).prop('checked', true);
});
</script>

<form id="upload" enctype="multipart/form-data" action="" method="post">
	<div class="dw-form-layout">
		<div class="dw-form-row">
			<?= $this->form->renderElement('file'); ?>
		</div>

		<div class="dw-toolbar">
			<?= $this->form->renderElement('submit'); ?>
		</div>
	</div>
</form>

<?php if (!empty($this->uploads)) : ?>
	<div id="uploads" style="display:none;">
		<?php foreach ($this->uploads as $id => $attachment): ?>
			<div id="attachment<?= (int) $id; ?>" class="dw-attachment-item">
				<label class="dw-attachment-item__select">
					<input type="checkbox" name="file[]" value="<?= (int) $id; ?>" checked>
					<span></span>
				</label>

				<a class="dw-attachment-item__link"
				   href="/files/attachments/<?= $this->escape($attachment['module']); ?>/<?= $this->escape($attachment['controller']); ?>/<?= $this->documentUrl; ?>/<?= rawurlencode($attachment['filename']); ?>"
				   target="_blank"
				   rel="noopener">
					<span class="dw-attachment-item__name"><?= $this->escape($attachment['filename']); ?></span>
					<span class="dw-attachment-item__meta">(<?= $this->HumanFileSize($attachment['filesize']); ?>)</span>
				</a>

				<button
					type="button"
					class="delete nolabel"
					onclick="deleteAttachment('<?= (int) $id; ?>', deleteConfirm, 'attachment', 'contacts');">
					Delete
				</button>
			</div>
		<?php endforeach; ?>
	</div>
<?php endif; ?>
