<?php

$actions = [
	'add' => 'ADMIN_ADD',
	'edit' => 'ADMIN_EDIT',
	'view' => 'ADMIN_VIEW',
	'delete' => 'ADMIN_DELETE',
];

$permissionId = (int)($this->permission['id'] ?? 0);
?>

<form id="permission-form" method="post">
	<div class="dw-permissions">
		<?php foreach ($this->modules as $module): ?>
			<?php
			$controllers = $this->permission[$module] ?? [];

			if (!is_array($controllers) || !$controllers) {
				continue;
			}
			?>

			<section class="dw-card dw-permission-module">
				<h3 class="dw-card__title">
					<?php echo $this->escape(strtoupper($module)); ?>
				</h3>

				<div class="dw-table-wrap">
					<table class="dw-table dw-permission-table">
						<thead>
							<tr>
								<th class="dw-permission-controller">
									<?php echo $this->translate('ADMIN_CONTROLLER'); ?>
								</th>

								<?php foreach ($actions as $action => $label): ?>
									<th class="dw-permission-action">
										<label class="dw-checkbox">
											<input
												type="checkbox"
												class="dw-permission-all"
												data-permission-module="<?php echo $this->escape($module); ?>"
												data-permission-action="<?php echo $this->escape($action); ?>"
											>

											<span>
												<?php echo $this->translate($label); ?>
											</span>
										</label>
									</th>
								<?php endforeach; ?>
							</tr>
						</thead>

						<tbody>
							<?php foreach ($controllers as $controller => $enabledActions): ?>
								<tr>
									<td class="dw-permission-controller">
										<?php echo $this->escape($controller); ?>
									</td>

									<?php foreach (['add', 'edit', 'view', 'delete'] as $action): ?>
										<?php
										$checked = in_array(
											$action,
											(array)$enabledActions,
											true
										);

										$name = implode('__', [
											$module,
											$controller,
											$action,
										]);
										?>

										<td class="dw-permission-action">
											<label class="dw-checkbox dw-permission-checkbox">
												<input
													type="checkbox"
													class="dw-permission-item"
													name="<?php echo $this->escape($name); ?>"
													data-permission-module="<?php echo $this->escape($module); ?>"
													data-permission-action="<?php echo $this->escape($action); ?>"
													data-module="admin"
													data-controller="permission"
													data-id="<?php echo $permissionId; ?>"
													value="1"
													<?php echo $checked ? 'checked="checked"' : ''; ?>
												>
											</label>
										</td>
									<?php endforeach; ?>
								</tr>
							<?php endforeach; ?>
						</tbody>
					</table>
				</div>
			</section>
		<?php endforeach; ?>
	</div>
</form>
