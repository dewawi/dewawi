<?php

$actions = [
	'add' => 'ADMIN_ADD',
	'edit' => 'ADMIN_EDIT',
	'view' => 'ADMIN_VIEW',
	'delete' => 'ADMIN_DELETE',
];

$permissionId = (int)$this->permission['id'];
?>

<div class="dw-permissions">
	<?php foreach ($this->modules as $module): ?>
		<?php
		$controllers = $this->permission[$module] ?? [];

		if (!is_array($controllers) || !$controllers) {
			continue;
		}
		?>

		<section class="dw-permission-module">
			<h3><?php echo $this->escape(strtoupper($module)); ?></h3>

			<div class="dw-permission-table">
				<div class="dw-permission-row dw-permission-header">
					<div class="dw-permission-controller">
						<?php echo $this->translate('ADMIN_CONTROLLER'); ?>
					</div>

					<?php foreach ($actions as $label): ?>
						<div class="dw-permission-action">
							<?php echo $this->translate($label); ?>
						</div>
					<?php endforeach; ?>
				</div>

				<?php foreach ($controllers as $controller => $enabledActions): ?>
					<div class="dw-permission-row">
						<div class="dw-permission-controller">
							<?php echo $this->escape($controller); ?>
						</div>

						<?php foreach ($actions as $action => $label): ?>
							<?php
							$checked = in_array(
								$action,
								(array)$enabledActions,
								true
							);
							?>

							<div class="dw-permission-action">
								<input
									type="checkbox"
									class="editable"
									name="<?php echo $this->escape($action); ?>"
									data-name="<?php echo $this->escape($action); ?>"
									data-module="admin"
									data-controller="permission"
									data-id="<?php echo $permissionId; ?>"
									data-element="<?php echo $this->escape($action); ?>"
									data-permission-module="<?php echo $this->escape($module); ?>"
									data-permission-controller="<?php echo $this->escape($controller); ?>"
									value="1"
									<?php echo $checked ? 'checked="checked"' : ''; ?>
								>
							</div>
						<?php endforeach; ?>
					</div>
				<?php endforeach; ?>
			</div>
		</section>
	<?php endforeach; ?>
</div>
