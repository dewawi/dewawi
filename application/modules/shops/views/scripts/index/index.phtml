<?php
//$this->title = $this->translate('SHOPS_ACCOUNTS');
//$this->headTitle($this->title);
//echo $this->Messages();
?>

<?php

if(isset($this->page)) :
	$content = $this->page['content'];
else :
	$content = '';
endif;

// Fetch data
$tags = $this->{'tags'};
$categories = $this->{'categories'};
$contact = $this->ContactForm($this->translate('SHOPS_CONTACT_FORM'));

// Construct HTML content for tags
$tagHtml = '<div class="row">';
if ($tags) {
	foreach ($tags as $tag) {
		if ($tag->slug) {
			$tagHtml .= '<div class="col-md-3 mb-3 px-2 d-flex align-items-stretch">';
			$tagHtml .= '<div class="card">';
			$tagHtml .= '<a href="' . $this->url(array('tag' => $tag->slug), $tag->slug) . '">';
			//$tagHtml .= '<img src="' . $this->baseUrl() . '/media/tag/' . $tag->image . '" class="card-img-top" alt="tag Image">';
			$tagHtml .= '</a>';
			$tagHtml .= '<div class="card-body">';
			$tagHtml .= '<a href="' . $this->url(array('tag' => $tag->slug), $tag->slug) . '">';
			$tagHtml .= '<h5 class="card-title">' . $tag->title . '</h5>';
			$tagHtml .= '</a>';
			//$tagHtml .= '<p class="card-text">' . $tag->shortdescription . '</p>';
			$tagHtml .= '<a href="' . $this->url(array('tag' => $tag->slug), $tag->slug) . '" class="btn btn-primary">View Details</a>';
			$tagHtml .= '</div>';
			$tagHtml .= '</div>';
			$tagHtml .= '</div>';
		}
	}
}
$tagHtml .= '</div>';

// Construct HTML content for Categories
$categoryHtml = $this->RenderCategories($categories);

// Replace the placeholder with the HTML content
$content = str_replace('{tags}', $tagHtml, $content);
$content = str_replace('{categories}', $categoryHtml, $content);
$content = str_replace('{contact}', $contact, $content);
?>

<?php if (!empty($this->slides)) : ?>
	<section id="carousel" class="carousel slide" data-ride="carousel" data-interval="5000">
		<ol class="carousel-indicators">
			<?php foreach ($this->slides as $index => $slideImage) : ?>
				<li data-target="#carousel"
					data-slide-to="<?php echo $index; ?>"
					<?php echo $index === 0 ? 'class="active"' : ''; ?>></li>
			<?php endforeach; ?>
		</ol>

		<div class="carousel-inner">
			<?php foreach ($this->slides as $index => $slideImage) : ?>
				<?php
				$imageUrl = $this->baseUrl()
					. '/media/slide/'
					. ltrim((string)$slideImage['url'], '/');

				$target = trim((string)($slideImage['target'] ?? ''));
				?>

				<div class="carousel-item<?php echo $index === 0 ? ' active' : ''; ?>">
					<?php if ($target !== '') : ?>
						<a href="<?php echo $this->escape($target); ?>">
					<?php endif; ?>

					<img src="<?php echo $this->escape($imageUrl); ?>"
						 class="d-block w-100"
						 alt="<?php echo $this->escape($slideImage['title'] ?? ''); ?>">

					<?php if ($target !== '') : ?>
						</a>
					<?php endif; ?>

					<div class="carousel-caption d-md-block text-left align-middle">
						<?php if (!empty($slideImage['title'])) : ?>
							<h2><?php echo $this->escape($slideImage['title']); ?></h2>
						<?php endif; ?>

						<?php if (!empty($slideImage['description'])) : ?>
							<p><?php echo $this->escape($slideImage['description']); ?></p>
						<?php endif; ?>
					</div>
				</div>
			<?php endforeach; ?>
		</div>
	</section>
<?php endif; ?>

<section id="about" class="py-5">
	<div class="container">
		<?php echo $content; ?>
	</div>
</section>
