$button = function ($action, $class, array $data = array(), $label = '') {
	$attrs = array(
		'type' => 'button',
		'class' => trim('dw-btn ' . $class),
		'data-action' => $action,
		'aria-label' => $action,
	);

	foreach ($data as $key => $value) {
		if ($value === null || $value === '') {
			continue;
		}

		$attrs['data-' . $key] = $value;
	}

	$html = '<button';

	foreach ($attrs as $key => $value) {
		$html .= ' ' . htmlspecialchars($key, ENT_QUOTES, 'UTF-8') . '="' . htmlspecialchars((string)$value, ENT_QUOTES, 'UTF-8') . '"';
	}

	$html .= '>';

	if ($label !== '') {
		$html .= '<span>' . htmlspecialchars($label, ENT_QUOTES, 'UTF-8') . '</span>';
	}

	$html .= '</button>';

	return $html;
};
