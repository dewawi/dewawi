<?php
$uploadUrl = $this->baseUrl()
	. '/contacts/attachment/upload/cmodule/' . urlencode((string) $this->module)
	. '/ccontroller/' . urlencode((string) $this->controller)
	. '/id/' . (int) $this->id;
?>

<div class="dw-email-composer">
	<form id="emailmessage" class="dw-email-composer__form" enctype="application/x-www-form-urlencoded" method="post">
		<div class="dw-form-row">
			<div class="dw-field dw-field--col-8">
				<div class="dw-email-card">
					<div class="dw-form-row">
						<?php if ($this->module !== 'campaigns') : ?>
							<?= $this->emailForm->renderElement('recipient'); ?>
						<?php endif; ?>

						<?= $this->emailForm->renderElement('cc'); ?>
						<?= $this->emailForm->renderElement('bcc'); ?>
						<?= $this->emailForm->renderElement('replyto'); ?>
						<?= $this->emailForm->renderElement('subject'); ?>

						<div class="dw-field dw-field--col-12">
							<label class="dw-label" for="attachments">
								<?= $this->translate('CONTACTS_ATTACHMENTS'); ?>
							</label>

							<div id="attachments" class="dw-attachment-list">
								<?php if (!empty($this->attachments)) : ?>
									<?php foreach ($this->attachments as $attachment) : ?>
										<?php
										$attachmentId = (int) $attachment['id'];
										$filename = (string) $attachment['filename'];

										$attachmentUrl = $this->baseUrl()
											. '/files/attachments/' . rawurlencode((string) $attachment['module'])
											. '/' . rawurlencode((string) $attachment['controller'])
											. '/' . rawurlencode((string) $this->documentUrl)
											. '/' . rawurlencode($filename);
										?>
										<div id="attachment<?= $attachmentId; ?>" class="dw-attachment-item">
											<label class="dw-attachment-item__select">
												<input type="checkbox" value="<?= $attachmentId; ?>" name="file[]">
												<span></span>
											</label>

											<a class="dw-attachment-item__link" href="<?= $attachmentUrl; ?>" target="_blank" rel="noopener">
												<span class="dw-attachment-item__name"><?= $this->escape($filename); ?></span>
												<span class="dw-attachment-item__meta">
													(<?= $this->HumanFileSize($attachment['filesize']); ?>)
												</span>
											</a>

											<button
												type="button"
												class="delete nolabel"
												onclick="deleteAttachment('<?= $attachmentId; ?>', deleteConfirm, 'attachment', 'contacts');"
											>
												Delete
											</button>
										</div>
									<?php endforeach; ?>
								<?php else : ?>
									<div class="dw-attachment-list__empty">
										<?= $this->translate('CONTACTS_NO_ATTACHMENTS'); ?>
									</div>
								<?php endif; ?>
							</div>
						</div>

						<?= $this->emailForm->renderElement('body'); ?>

						<div class="dw-field dw-field--col-12">
							<div class="dw-email-composer__actions">
								<button type="button" class="send dw-btn dw-btn--primary" onclick="sendMessage()">
									<?= $this->translate('SEND'); ?>
								</button>
							</div>
						</div>
					</div>
				</div>
			</div>

			<div class="dw-field dw-field--col-4">
				<div class="dw-email-card">
					<h4 class="dw-email-card__title">
						<?= $this->translate('CONTACTS_ATTACHMENTS'); ?>
					</h4>

					<iframe
						src="<?= $uploadUrl; ?>"
						class="dw-email-upload-frame"
						title="Attachment upload"
						height="420"
					></iframe>
				</div>
			</div>
		</div>
	</form>

	<div id="emailmessages" class="dw-email-history"></div>
</div>
