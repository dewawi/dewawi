$visibleSections = [];

foreach ($sections as $historyKey => $section) {
	if (!empty($this->history[$historyKey]) && count($this->history[$historyKey])) {
		$visibleSections[$historyKey] = $section;
	}
}

$firstTabKey = array_key_first($visibleSections);

function normalizeHistoryRows($rows, array $section): array
{
	$out = [];

	foreach ($rows as $row) {
		if ($row instanceof Zend_Db_Table_Row_Abstract) {
			$data = $row->toArray();
		} elseif (is_object($row) && method_exists($row, 'toArray')) {
			$data = $row->toArray();
		} else {
			$data = (array)$row;
		}

		$item = new stdClass();

		foreach ($data as $key => $value) {
			if (strpos((string)$key, "\0") !== false) {
				continue;
			}

			$item->{$key} = $value;
		}

		$docIdField = $section['docIdField'];
		$dateField = $section['dateField'];

		$item->module = $section['module'];
		$item->controller = $section['controller'];
		$item->document_number = $data[$docIdField] ?? $data['id'] ?? '';
		$item->document_date = $dateField ? ($data[$dateField] ?? '') : '';

		$out[] = $item;
	}

	return $out;
}
